    "@upstash/redis": "^1.38.0",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "negotiator": "^1.0.0",
    "next": "16.2.10",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "6.8.1",
    "resend": "^6.17.2",
    "sonner": "^2.0.7",
