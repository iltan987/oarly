{
  "name": "oarly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/oarly_test vitest run --no-file-parallelism",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "auth:generate": "better-auth generate --config ./src/auth.ts --output ./src/db/schema/auth.ts"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.12",
    "@t3-oss/env-nextjs": "^0.13.11",
